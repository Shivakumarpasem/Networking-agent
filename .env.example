# Copy this file to .env and fill in your values
# Never commit .env — it is in .gitignore

# Get your Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# PostgreSQL connection string
# Local: postgresql://postgres:yourpassword@localhost:5432/networking_agent
# Neon (free cloud): postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# Railway: automatically set as DATABASE_URL when you add a Postgres plugin
DATABASE_URL=your_postgresql_connection_string_here

PORT=3001
